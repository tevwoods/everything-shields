{"name":"Magnetic Token","type":"consumable","img":"systems/pf2e/icons/equipment/consumables/other-consumables/dimensional-knot.webp","system":{"description":{"value":"<p><strong>Activate&nbsp;</strong><span class=\"pf2-icon\">f&nbsp;</span>command; <strong>Trigger&nbsp;</strong>You use @UUID[Compendium.pf2e.feats-srd.jM72TjJ965jocBV8]{Shield Block} to reduce the damage from an attack made with a metal weapon.</p>\n<hr>\n<p>This token seems to shift position around the shield periodically and unpredictably. When activated you cause your shield to become magnetic. You may immediately attempt to @UUID[Compendium.pf2e.actionspf2e.Dt6B1slsBy8ipJu9]{Disarm} the blocked weapon and you gain a +1 circumstance bonus to this check.</p>"},"source":{"value":"Everything Shields"},"traits":{"value":["evocation","magical","talisman"],"rarity":"common","custom":"","otherTags":[]},"rules":[],"slug":null,"schema":{"version":0.93,"lastMigration":{"datetime":"2025-11-10T15:51:44.920Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"quantity":1,"baseItem":null,"hp":{"brokenThreshold":0,"value":0,"max":0},"hardness":0,"weight":{"value":"-"},"equippedBulk":{"value":""},"price":{"value":{"gp":40}},"equipped":{"carryType":"worn","handsHeld":0},"stackGroup":null,"negateBulk":{"value":"0"},"containerId":null,"preciousMaterial":{"value":null},"preciousMaterialGrade":{"value":null},"size":"med","identification":{"status":"identified","unidentified":{"name":"Unusual Object","img":"systems/pf2e/icons/unidentified_item_icons/other-consumables.webp","data":{"description":{"value":""}}},"misidentified":{}},"usage":{"value":"affixed-to-a-shield"},"activation":{"type":"","cost":0,"condition":""},"duration":{"value":null,"units":""},"target":{"value":null,"units":"","type":""},"range":{"value":null,"long":null,"units":""},"uses":{"value":0,"max":0,"per":null,"autoUse":true,"autoDestroy":true},"spell":null,"level":{"value":6},"consumableType":{"value":"talisman"},"charges":{"value":0,"max":