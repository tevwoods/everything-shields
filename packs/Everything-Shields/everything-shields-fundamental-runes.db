{"_id":"e2JCjAh4od5JImA7","name":"+3 Shield Potency Rune","type":"equipment","img":"systems/pf2e/icons/equipment/runes/fundamental-weapon-runes/weapon-potency.webp","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>Magic wards increase the durability of the shield. Increase the shield's Hit Point total by multiplying the base Hit Points of the shield by 7. The shield can be etched with three property runes.</p>\n<p>You can upgrade the shield potency rune already etched on a shield to a stronger version, increasing the values of the existing rune to those of the new rune. You must have the formula of the stronger rune to do so, and the Price of the upgrade is the difference between the runes' Prices.</p>\n<p>&nbsp;</p>\n<p><strong>Foundry Instructions:&nbsp;</strong>You can apply the effects of this rune to a shield in a character's inventory by dragging and dropping this rune to the character's sheet. After dropping the item on the character's sheet, you will be prompted by a dialog to choose which shield you would like to apply it to.&nbsp; You may also choose to just place it into your inventory at that time.</p>"},"source":{"value":"Everything Shields"},"traits":{"value":["abjuration","magical"],"rarity":"common","custom":"","otherTags":[]},"rules":[],"slug":null,"schema":{"version":0.93,"lastMigration":{"datetime":"2025-11-10T15:51:44.924Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"quantity":1,"baseItem":null,"hp":{"brokenThreshold":0,"value":0,"max":0},"hardness":0,"weight":{"value":"-"},"equippedBulk":{"value":""},"price":{"value":{"gp":8935}},"equipped":{"carryType":"worn","invested":null,"handsHeld":0},"stackGroup":"","negateBulk":{"value":"0"},"containerId":null,"preciousMaterial":{"value":null},"preciousMaterialGrade":{"value":null},"size":"med","identification":{"status":"identified","unidentified":{"name":"Unusual Object","img":"systems/pf2e/icons/unidentified_item_icons/adventuring_gear.webp","data":{"description":{"value":""}}},"misidentified":{}},"usage":{"value":"applied-to-shield"},"level":{"value":15}},"ownership":{"default":0,"4mqS4QLqshw8WhsN":3},"_stats":{"systemId":"pf2e","systemVersion":"4.3.4","coreVersion":"10.290","createdTime":null,"modifiedTime":1668741663072,"lastModifiedBy":"XyQNEFY9gmTDIpSd"},"schemaVersion":13}
{"_id":"gJ7GkSRmcDZWEa89","name":"+1 Shield Potency Rune","type":"equipment","img":"systems/pf2e/icons/equipment/runes/fundamental-weapon-runes/weapon-potency.webp","effects":[],"folder":null,"sort":0,"flags":{},"system":{"description":{"value":"<p>Magic wards increase the durability of the shield. Increase the shield's Hit Point total by multiplying the base Hit Points of the shield by 3. The shield can be etched with one property rune.</p>\n<p>You can upgrade the shield potency rune already etched on a shield to a stronger version, increasing the values of the existing rune to those of the new rune. You must have the formula of the stronger rune to do so, and the Price of the upgrade is the difference between the runes' Prices.</p>\n<p>&nbsp;</p>\n<p><strong>Foundry Instructions:&nbsp;</strong>You can apply the effects of this rune to a shield in a character's inventory by dragging and dropping this rune to the character's sheet. After dropping the item on the character's sheet, you will be prompted by a dialog to choose which shield you would like to apply it to.&nbsp; You may also choose to just place it into your inventory at that time.</p>"},"source":{"value":"Everything Shields"},"traits":{"value":["abjuration","magical"],"rarity":"common","custom":"","otherTags":[]},"rules":[],"slug":null,"schema":{"version":0.93,"lastMigration":{"datetime":"2025-11-10T15:51:44.924Z","version":{"schema":0.93,"foundry":"13","system":"6.0.0"}}},"quantity":1,"baseItem":null,"hp":{"brokenThreshold":0,"value":0,"max":0},"hardness":0,"weight":{"value":"-"},"equippedBulk":{"value":""},"price":{"value":{"gp":35}},"equipped":{"carryType":"worn","invested":null,"handsHeld":0},"stackGroup":"","negateBulk":{"value":"0"},"containerId":null,"preciousMaterial":{"value":null},"preciousMaterialGrade":{"value":null},"size":"med","identification":{"status":"identified","unidentified":{"name":"Unusual Object","img":"systems/pf2e/icons/unidentified_item_icons/adventuring_gear.webp","data":{"desc